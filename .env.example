# Copy this to .env for local development
# Never commit .env to git

# PostgreSQL connection string
# Local:   postgres://postgres:password@localhost:5432/bulk_backend
# Neon:    postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/bulk_backend?sslmode=require
# Supabase: postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:password@localhost:5432/bulk_backend

# The exact origin of your deployed frontend (no trailing slash)
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Port (Railway sets this automatically, so usually leave it unset locally)
# PORT=8080

# Log level (info | debug | warn | error)
RUST_LOG=bulk_backend=info,tower_http=info
